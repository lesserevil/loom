# Loom — environment variables
# Copy this to .env for local development. Never commit .env.

# LLM Provider (required for agents to work)
# Set to any OpenAI-compatible endpoint. Examples:
#   LOOM_PROVIDER_URL=https://api.openai.com/v1          # OpenAI
#   LOOM_PROVIDER_URL=http://localhost:11434/v1           # Ollama
#   LOOM_PROVIDER_URL=http://localhost:8080/v1            # vLLM, LiteLLM, TokenHub, etc.
LOOM_PROVIDER_URL=

# API key for the provider endpoint, if required
LOOM_PROVIDER_API_KEY=

# Git tokens for agent repo access
GITLAB_TOKEN=
GITHUB_TOKEN=

# Optional: password for the Loom web UI (blank = no password)
# LOOM_PASSWORD=
